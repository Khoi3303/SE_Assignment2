@model Web_Assignment2.Models.Order
@{ ViewBag.Title = "Lập Đơn Hàng"; }

<h2 style="margin-top:20px;">Lập Đơn Hàng Mới</h2>
<hr />

<div style="background-color:#f9f9f9; padding:20px; border-radius:8px; margin-bottom:20px;">
    <h4>1. Chọn sản phẩm mua</h4>
    <form action="/Orders/AddToCart" method="post" style="display:flex; gap:15px; align-items:flex-end;">
        <div>
            <label>Sản phẩm:</label>
            @Html.DropDownList("ItemID", null, htmlAttributes: new { @class = "form-control", style = "min-width:250px;" })
        </div>
        <div>
            <label>Số lượng:</label>
            <input type="number" name="Quantity" value="1" min="1" class="form-control" style="width:100px;" required />
        </div>
        <div>
            <button type="submit" class="btn btn-primary">Thêm vào giỏ</button>
        </div>
    </form>
</div>

<h4>2. Giỏ hàng hiện tại</h4>
<table class="table table-bordered table-striped">
    <thead style="background-color:#337ab7; color:white;">
        <tr>
            <th>Tên SP</th>
            <th>Số lượng</th>
            <th>Đơn giá</th>
            <th>Thành tiền</th>
        </tr>
    </thead>
    <tbody>
        @{
            var cart = Session["Cart"] as List<Web_Assignment2.Models.CartItem>; 
            int total = 0;
            if (cart != null && cart.Count > 0)
            {
                foreach (var item in cart)
                {
                    <tr>
                        <td>@item.ItemName</td>
                        <td>@item.Quantity</td>
                        <td>@item.UnitAmount.ToString("N0")</td>
                        <td>@item.SubTotal.ToString("N0")</td>
                    </tr>
                    total += item.SubTotal;
                }
            }
            else
            {
                <tr><td colspan="4" class="text-center">Giỏ hàng đang trống</td></tr>
            }
        }
        <tr style="font-weight:bold; font-size:18px;">
            <td colspan="3" class="text-right">TỔNG CỘNG:</td>
            <td style="color:red;">@total.ToString("N0") VNĐ</td>
        </tr>
    </tbody>
</table>

<div style="background-color:#e6f7ff; padding:20px; border-radius:8px; border:1px solid #bce8f1;">
    <h4>3. Xác nhận và Lưu Đơn hàng</h4>
    <form action="/Orders/SaveOrder" method="post">
        <label>Đại lý mua hàng:</label>
        @Html.DropDownList("AgentID", null, htmlAttributes: new { @class = "form-control", style = "max-width:400px; margin-bottom:15px;" })
        <button type="submit" class="btn btn-success btn-lg">LƯU ĐƠN HÀNG</button>
    </form>
</div>

<div>
    <br />
    @Html.ActionLink("Quay lại danh sách", "Index")
</div>